generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  gameSave      GameSave?
  villages      WorldTile[] @relation("PlayerVillages")
  commands      CombatCommand[] @relation("PlayerCommands")
  chatMessages  ChatMessage[]
  bugReports    BugReport[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Existing user save (backup/legacy)
model GameSave {
  id         String   @id @default(cuid())
  userId     String   @unique
  playerName String   @default("Player_1")
  state      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NEW: Global shared World Map
model WorldTile {
  id          String   @id @default(cuid())
  x           Int
  y           Int
  type        String   // empty, grass, village, player, forest, water, mountain
  ownerId     String?
  ownerName   String?
  name        String?
  buildings   Json?
  resources   Json?
  units       Json?
  upgrades    Json?   // build queue: UpgradeEntry[]
  recruitment Json?   // training queue: RecruitmentEntry[]
  endorsement Int?     @default(100)
  scoutedAt   DateTime?
  lastAttackAt DateTime?
  updatedAt   DateTime @updatedAt
  user        User?    @relation("PlayerVillages", fields: [ownerId], references: [id])

  @@unique([x, y])
}

// NEW: Global shared troop movements
model CombatCommand {
  id               String   @id @default(cuid())
  type             String   // attack, scout
  status           String   // marching, returning
  originX          Int
  originY          Int
  targetX          Int
  targetY          Int
  units            Json
  loot             Json?
  arrivesAt        DateTime
  returnsAt        DateTime?
  ownerId          String
  targetOwnerId    String?
  createdAt        DateTime @default(now())
  user             User     @relation("PlayerCommands", fields: [ownerId], references: [id])
}

// Global chat
model ChatMessage {
  id         String   @id @default(cuid())
  content    String
  authorId   String
  authorName String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [authorId], references: [id])
}

// Bug reports
model BugReport {
  id           String   @id @default(cuid())
  description  String
  page         String?
  reporterId   String?
  reporterName String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [reporterId], references: [id])
}
